# Kök dizindeki .env ile aynı anahtarları kullanabilirsiniz (content_manager kök .env dosyasını da okur).

GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI: DALL-E 3 kapak görselleri (public/images/covers/)
OPENAI_API_KEY=

# Google AI Studio / Gemini API model adı. Projedeki Next tarafı varsayılanı: gemini-3-flash
# Hesabınızda hangi model açıksa onu yazın; örnekler: gemini-2.0-flash, gemini-3-flash, gemini-3.1-flash-preview
GEMINI_MODEL=gemini-3-flash

# Supabase PostgreSQL (Prisma + Python ile aynı URI)
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# Virgülle ayrılmış RSS adresleri (hukuk / genel haber kaynaklarınızı ekleyin)
RSS_FEEDS=https://www.aa.com.tr/tr/rss?cat=guncel

# İsteğe bağlı: makale gövdesinin başına eklenecek görsel (Markdown). Boş bırakılırsa eklenmez.
IMAGE_PLACEHOLDER_URL=https://images.unsplash.com/photo-1589829545856-d10d557cf95f?auto=format&fit=crop&q=80&w=1200
