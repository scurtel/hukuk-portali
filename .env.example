# Supabase: Project Settings → Database → Connection string → URI (Transaction veya Session)
# Örnek: postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"
GEMINI_API_KEY="your_gemini_api_key"
# DALL-E 3 kapak gorselleri (content_manager) icin
OPENAI_API_KEY=""
# Python otomasyonu (crawler / content_manager) icin, virgulle ayirilmis RSS URL'leri
RSS_FEEDS=""
# Isteg bagli: gemini-3-flash, gemini-2.0-flash vb. (Hesabinizda acik olan model)
GEMINI_MODEL="gemini-3-flash"
ADMIN_PASSWORD=123456
